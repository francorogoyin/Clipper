# Base de datos.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/highlighter

# Redis.
REDIS_URL=redis://localhost:6379/0

# JWT.
SECRET_KEY=generar-con-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# OAuth Google.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# OAuth Notion.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8000/api/auth/notion/callback

# S3 / Cloudflare R2.
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=highlighter
S3_REGION=auto

# Fernet (generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())").
FERNET_KEY=

# Frontend.
FRONTEND_URL=http://localhost:5173
